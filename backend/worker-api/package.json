{
  "name": "@toko-kue/worker-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply toko-kue-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply toko-kue-db --remote",
    "d1:execute:local": "wrangler d1 execute toko-kue-db --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260215.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.66.0"
  }
}
